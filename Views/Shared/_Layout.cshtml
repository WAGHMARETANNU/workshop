<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - School Management System</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>

<body>

    <!-- TOP NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="#">School MS</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" 
                    data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="#">Admin</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Logout</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTAINER -->
    <div class="container-fluid">
        <div class="row">

            <!-- SIDEBAR -->
            <div class="col-md-2 bg-light vh-100 p-3 border-end">

                <ul class="nav nav-pills flex-column mb-auto">

                    <li class="nav-item mb-2">
                        <a asp-controller="Home" asp-action="Index" 
                           class="nav-link active">
                            Dashboard
                        </a>
                    </li>

                    <li class="nav-item mb-2">
                        <a asp-controller="Students" asp-action="Index" 
                           class="nav-link text-dark">
                            Students
                        </a>
                    </li>

                    <li class="nav-item mb-2">
                        <a asp-controller="Teachers" asp-action="Index" 
                           class="nav-link text-dark">
                            Teachers
                        </a>
                    </li>

                    <li class="nav-item mb-2">
                        <a asp-controller="Classes" asp-action="Index" 
                           class="nav-link text-dark">
                            Courses
                        </a>
                    </li>

                    <li class="nav-item mb-2">
                        <a asp-controller="Fees" asp-action="Index" 
                           class="nav-link text-dark">
                            Attendance
                        </a>
                    </li>

                    <li class="nav-item mb-2">
                        <a asp-controller="Reports" asp-action="Index" 
                           class="nav-link text-dark">
                            Logout
                        </a>
                    </li>

                </ul>

            </div>

            <!-- CONTENT AREA -->
            <main class="col-md-10 p-4">

                @RenderBody()

            </main>

        </div>
    </div>

    <!-- FOOTER -->
    <footer class="bg-dark text-white text-center p-3">
        © @DateTime.Now.Year School Management System | Developed in ASP.NET Core
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>