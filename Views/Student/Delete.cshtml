@model workshop.Models.StudentModel

@{
    ViewData["Title"] = "Delete Student";
}

<div class="container mt-4">

    <div class="card shadow border-danger">
        <div class="card-header bg-danger text-white">
            <h4>Delete Student</h4>
        </div>

        <div class="card-body">

            <h5>Are you sure you want to delete this student?</h5>

            <hr />

            <dl class="row">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.studentname</dd>

                <dt class="col-sm-3">Branch</dt>
                <dd class="col-sm-9">@Model.studentbranch</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.student_email</dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="student_id" />

                <button type="submit" class="btn btn-danger">
                    Delete
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Cancel
                </a>
            </form>

        </div>
    </div>

</div>