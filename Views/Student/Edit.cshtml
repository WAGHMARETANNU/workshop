@model workshop.Models.StudentModel

@{
    ViewData["Title"] = "Edit Student";
}

<div class="container mt-4">

    <div class="card shadow">
        <div class="card-header bg-warning">
            <h4>Edit Student</h4>
        </div>

        <div class="card-body">
            <form asp-action="Edit" method="post">

                <input type="hidden" asp-for="student_id" />

                <div class="mb-3">
                    <label asp-for="studentname" class="form-label"></label>
                    <input asp-for="studentname" class="form-control" />
                    <span asp-validation-for="studentname" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="studentbranch" class="form-label"></label>
                    <input asp-for="studentbranch" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="student_email" class="form-label"></label>
                    <input asp-for="student_email" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="DOB" class="form-label"></label>
                    <input asp-for="DOB" type="date" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="city" class="form-label"></label>
                    <input asp-for="city" class="form-control" />
                </div>

                <button type="submit" class="btn btn-warning">Update</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>

            </form>
        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}